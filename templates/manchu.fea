languagesystem DFLT dflt;
languagesystem mong dflt;
@fvs1 = [fvs1 fvs1.valid fvs1.ignored];
@fvs2 = [fvs2 fvs2.valid fvs2.ignored];
@fvs3 = [fvs3 fvs3.valid fvs3.ignored];
@fvs4 = [fvs4 fvs4.valid fvs4.ignored];
@mvs = [mvs mvs.narrow mvs.wide nnbsp];
@mvs.invalid = [mvs nnbsp];
@mvs.valid = [mvs.narrow mvs.wide];
@fvs.invalid = [fvs1 fvs2 fvs3 fvs4];
@fvs.valid = [fvs1.valid fvs2.valid fvs3.valid fvs4.valid];
@fvs.ignored = [fvs1.ignored fvs2.ignored fvs3.ignored fvs4.ignored];
@fvs = [@fvs1 @fvs2 @fvs3 @fvs4];
lookup _.ignored {
    lookupflag 0;
    sub nirugu by nirugu.ignored;
    sub zwj by zwj.ignored;
    sub zwnj by zwnj.ignored;
    sub fvs1 by fvs1.ignored;
    sub fvs1.valid by fvs1.ignored;
    sub fvs2 by fvs2.ignored;
    sub fvs2.valid by fvs2.ignored;
    sub fvs3 by fvs3.ignored;
    sub fvs3.valid by fvs3.ignored;
    sub fvs4 by fvs4.ignored;
    sub fvs4.valid by fvs4.ignored;
} _.ignored;

lookup _.valid {
    lookupflag 0;
    sub fvs1 by fvs1.valid;
    sub fvs1.ignored by fvs1.valid;
    sub fvs2 by fvs2.valid;
    sub fvs2.ignored by fvs2.valid;
    sub fvs3 by fvs3.valid;
    sub fvs3.ignored by fvs3.valid;
    sub fvs4 by fvs4.valid;
    sub fvs4.ignored by fvs4.valid;
} _.valid;

lookup _.reset {
    lookupflag 0;
    sub mvs.narrow by mvs;
    sub mvs.wide by mvs;
    sub nirugu.ignored by nirugu;
    sub fvs1.ignored by fvs1;
    sub fvs1.valid by fvs1;
    sub fvs2.ignored by fvs2;
    sub fvs2.valid by fvs2;
    sub fvs3.ignored by fvs3;
    sub fvs3.valid by fvs3;
    sub fvs4.ignored by fvs4;
    sub fvs4.valid by fvs4;
} _.reset;

lookup _.narrow {
    lookupflag 0;
    sub mvs by mvs.narrow;
    sub mvs.wide by mvs.narrow;
    sub nnbsp by mvs.narrow;
} _.narrow;

lookup _.wide {
    lookupflag 0;
    sub mvs by mvs.wide;
    sub mvs.narrow by mvs.wide;
    sub nnbsp by mvs.wide;
} _.wide;

