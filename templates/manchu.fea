        sub [@MCH-t @MCH-d @MCH-k @MCH-g @MCH-h] u1860.Oh.fina' lookup MCH.feminine_marked;
        sub [@MCH-t @MCH-d @MCH-k @MCH-g @MCH-h] [@MCH-e @MCH-u]' lookup MCH.feminine;
    } III.e_u.feminine.SIB_MCH_MCHx;

