        sub [@MCH-k @MCH-g @MCH-h] @MCH-u @MCH-k' lookup MCH.feminine;
        sub [@MCH-kh @MCH-gh @MCH-hh] @MCH-a @MCH-k' lookup MCH.feminine;
        sub [@MCH-e @MCH-ue] @MCH-k' lookup MCH.feminine;
