feature ccmp {
    script mong;
    language dflt;
    lookup Ia.nnbsp.preprocessing {
        lookupflag 0;
        sub nnbsp by mvs;
    } Ia.nnbsp.preprocessing;

} ccmp;

feature isol {
    script mong;
