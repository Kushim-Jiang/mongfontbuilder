{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "npm run check && astro build",
    "preview": "astro preview",
    "format": "prettier --write . !lib/mongfontbuilder/data/*.json !tests/data/*.json"
  },
  "engines": {
    "node": "^24.11.0"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/starlight": "0.39.2",
    "@astrojs/svelte": "8.1.1",
    "@fontsource/noto-sans-mongolian": "5.2.6",
    "@types/node": "25.8.0",
    "@unicode/unicode-17.0.0": "1.6.16",
    "astro": "6.3.3",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-svelte": "3.5.2",
    "svelte": "5.55.7",
    "typescript": "6.0.3"
  },
  "overrides": {
    "lodash": "4.17.23"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.mdx",
        "options": {
          "printWidth": 10000
        }
      },
      {
        "files": "*.astro",
        "options": {
          "plugins": [
            "prettier-plugin-astro"
          ],
          "parser": "astro",
          "printWidth": 10000
        }
      },
      {
        "files": "*.svelte",
        "options": {
          "plugins": [
            "prettier-plugin-svelte"
          ],
          "parser": "svelte",
          "printWidth": 10000
        }
      }
    ]
  }
}
